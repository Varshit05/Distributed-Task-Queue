datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id           String    @id @default(uuid())
  name         String    // e.g., "send_email", "process_video"
  queue        String    @default("default")
  status       String    // "pending" | "processing" | "completed" | "failed" | "cancelled"
  payload      Json
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  timeoutMs    Int?      // Max execution duration in milliseconds
  delayMs      Int?      // Optional delay in milliseconds before executing when enqueued
  isEnqueued   Boolean   @default(false)
  runAt        DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  logs         TaskLog[]

  // Workflow relations
  workflowId   String?
  workflow     Workflow? @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // DAG Dependencies
  dependencies TaskDependency[] @relation("DownstreamTasks")
  dependents   TaskDependency[] @relation("UpstreamTasks")

  @@index([status, runAt])
}

model TaskLog {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  message   String
  level     String   @default("info") // "info" | "error"
  createdAt DateTime @default(now())
}

model CronJob {
  id           String    @id @default(uuid())
  name         String    @unique // E.g., "cleanup-job"
  taskName     String    // E.g., "send_email"
  expression   String    // Cron expression e.g. "*/5 * * * *"
  payload      Json      // Arguments passed to the task
  isActive     Boolean   @default(true)
  nextRunAt    DateTime  // Scheduled time for the next execution
  lastRunAt    DateTime? // Last time this job was successfully triggered
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive, nextRunAt])
}

model Workflow {
  id        String   @id @default(uuid())
  name      String
  status    String   // "running" | "completed" | "failed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model TaskDependency {
  id               String @id @default(uuid())
  upstreamTaskId   String
  upstreamTask     Task   @relation("UpstreamTasks", fields: [upstreamTaskId], references: [id], onDelete: Cascade)
  downstreamTaskId String
  downstreamTask   Task   @relation("DownstreamTasks", fields: [downstreamTaskId], references: [id], onDelete: Cascade)

  @@unique([upstreamTaskId, downstreamTaskId])
}

